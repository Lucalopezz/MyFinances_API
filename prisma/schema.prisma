generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  encryptedData Json
  dateIndex     Int
  type          TransactionType
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        String          @db.ObjectId

  @@index([userId, id])
  @@index([userId, dateIndex, id])
}

enum TransactionType {
  INCOME
  EXPENSE
}

type TransactionExportFilters {
  startDate  DateTime?
  endDate    DateTime?
  categoryId String?
  type       TransactionType?
}

model TransactionExport {
  id           String                    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String                    @db.ObjectId
  status       TransactionExportStatus
  progress     Int                       @default(0)
  filters      TransactionExportFilters?
  fileName     String?
  errorMessage String?
  createdAt    DateTime                  @default(now())
  completedAt  DateTime?

  @@index([userId, id])
  @@index([userId, createdAt, id])
}

enum TransactionExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model WishlistItem {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  desiredValue Float
  savedAmount  Float     @default(0)
  targetDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String    @db.ObjectId
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  userId    String           @db.ObjectId
}

enum NotificationType {
  ALERT
  REMINDER
  INFO
}

model FixedExpense {
  id                      String         @id @default(auto()) @map("_id") @db.ObjectId
  name                    String
  amount                  Float
  category                String         @default("UTILITIES")
  dueDate                 DateTime
  isPaid                  Boolean        @default(false)
  paidAt                  DateTime?
  paidTransactionId       String?
  recurrence              RecurrenceType
  lastNotificationDueDate DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  userId                  String         @db.ObjectId
}

enum RecurrenceType {
  MONTHLY
  YEARLY
}
